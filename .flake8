[flake8]
max-line-length = 88
max-complexity = 10
exclude = 
    .git,
    __pycache__,
    .venv,
    .eggs,
    *.egg,
    build,
    dist,
    data,
    htmlcov,
    .mypy_cache,
    .pytest_cache

# Error codes to ignore
ignore = 
    E203,  # whitespace before ':'
    E501,  # line too long (handled by black)
    W503,  # line break before binary operator
    W504,  # line break after binary operator
    F401,  # imported but unused (handled by isort/mypy)

# Error codes to enforce
select = E,W,F,C

per-file-ignores =
    __init__.py:F401
    tests/*:F401,F811
    src/ui/*:F401,E501