# API Keys for Portfolio Tracker
# Copy this file to .env and add your actual API keys

# OpenAI API Key for AI agent (required for chat functionality)
OPENAI_API_KEY=your_openai_api_key_here

# Alpha Vantage API Key for financial data (optional, free tier available)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Optional: Custom data directory
# DATA_DIR=data

# Optional: Log level
# LOG_LEVEL=INFO